# HealthLife — Environment Variables Reference
# Copy this file to .env and fill in the values.
# NEVER commit .env with real secrets to git.
#
# For Kubernetes production: use External Secrets Operator (k8s/base/external-secrets.yaml)
# For local development: set these in your shell or IDE run configuration

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — all services
# ─────────────────────────────────────────────────────────────────────────────

# JWT signing key — minimum 32 characters (256 bits)
# Generate: openssl rand -base64 64
JWT_SECRET=REPLACE_ME_WITH_A_SECURE_256BIT_OR_LONGER_SECRET_KEY_AT_LEAST_32_CHARS

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — services with PostgreSQL (auth, user, health-data, mental,
#            nutrition, ai-coach, social, payment)
# ─────────────────────────────────────────────────────────────────────────────

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/healthlife_auth
SPRING_DATASOURCE_USERNAME=healthlife
SPRING_DATASOURCE_PASSWORD=healthlife_pass

# ─────────────────────────────────────────────────────────────────────────────
# REDIS — gateway, auth, notification, analytics
# ─────────────────────────────────────────────────────────────────────────────

SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL (SMTP) — auth-service (verification, password reset)
# ─────────────────────────────────────────────────────────────────────────────

# SMTP host — use smtp.gmail.com for Gmail, email-smtp.us-east-1.amazonaws.com for SES,
#              smtp.sendgrid.net for SendGrid
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
# Protocol: smtp (default) or smtps
MAIL_PROTOCOL=smtp
# Enable SSL — set to true for port 465 (SendGrid, SES)
MAIL_SSL_ENABLE=false

# ─────────────────────────────────────────────────────────────────────────────
# AI COACH — ai-coach-service (DeepSeek)
# ─────────────────────────────────────────────────────────────────────────────

# DeepSeek API key — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...

# DeepSeek model — valid options include deepseek-chat and deepseek-v3
DEEPSEEK_MODEL=deepseek-chat

# Thread pool size for blocking DeepSeek API calls (default: 20)
AI_EXECUTOR_CORE_THREADS=20

# ─────────────────────────────────────────────────────────────────────────────
# FIREBASE — notification-service (push notifications)
# ─────────────────────────────────────────────────────────────────────────────

# Full JSON content of Firebase service account key
# Download: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ─────────────────────────────────────────────────────────────────────────────
# STRIPE — payment-service
# ─────────────────────────────────────────────────────────────────────────────

# Stripe secret key — https://dashboard.stripe.com/apikeys
# Use sk_test_... for testing, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret — Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe price IDs — Stripe Dashboard → Products → your product → Prices
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PREMIUM=price_...
STRIPE_PRICE_FAMILY=price_...

# Redirect URLs after Stripe Checkout
STRIPE_SUCCESS_URL=https://app.healthlife.com/subscription/success
STRIPE_CANCEL_URL=https://app.healthlife.com/subscription/cancel

# ─────────────────────────────────────────────────────────────────────────────
# OAUTH2 — auth-service (Google / Apple Sign-In)
# ─────────────────────────────────────────────────────────────────────────────

# Google OAuth2 client ID — Google Cloud Console → APIs & Services → Credentials
# Must match the client ID used in the mobile app's Google Sign-In configuration
OAUTH_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Apple Sign-In — no server-side secret needed.
# Configure your Apple App ID in Apple Developer Console → Certificates, IDs & Profiles.
OAUTH_APPLE_AUDIENCE=com.healthlife.app

# ─────────────────────────────────────────────────────────────────────────────
# CORS — all services
# ─────────────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ─────────────────────────────────────────────────────────────────────────────
# GATEWAY ROUTES — gateway-service (override for non-default ports/hosts)
# ─────────────────────────────────────────────────────────────────────────────

GATEWAY_ROUTE_AUTH=http://localhost:8081
GATEWAY_ROUTE_USERS=http://localhost:8082
GATEWAY_ROUTE_HEALTH=http://localhost:8083
GATEWAY_ROUTE_MENTAL=http://localhost:8084
GATEWAY_ROUTE_NUTRITION=http://localhost:8085
GATEWAY_ROUTE_AI=http://localhost:8086
GATEWAY_ROUTE_SOCIAL=http://localhost:8087
GATEWAY_ROUTE_NOTIFICATIONS=http://localhost:8088
GATEWAY_ROUTE_ANALYTICS=http://localhost:8089
GATEWAY_ROUTE_PAYMENTS=http://localhost:8090

# ─────────────────────────────────────────────────────────────────────────────
# MONITORING — deploy-monitoring.sh
# ─────────────────────────────────────────────────────────────────────────────

GRAFANA_ADMIN_PASSWORD=REPLACE_ME_WITH_STRONG_PASSWORD
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
PAGERDUTY_ROUTING_KEY=...
ALERTMANAGER_SMTP_HOST=smtp.gmail.com:587
ALERTMANAGER_SMTP_USER=alerts@healthlife.com
ALERTMANAGER_SMTP_PASSWORD=...

# ─────────────────────────────────────────────────────────────────────────────
# LOAD TESTS — k6
# ─────────────────────────────────────────────────────────────────────────────

STAGING_HEALTH_URL=https://staging.healthlife.com
LOAD_TEST_USER_EMAIL=loadtest@healthlife.com
LOAD_TEST_USER_PASSWORD=LoadTest@2025!
