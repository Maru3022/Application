# ══════════════════════════════════════════════════════════════
#  HealthLife — Environment Variables Template
#  Copy to .env and fill in all values before running:
#    cp .env.example .env
#    docker compose up -d --build
# ══════════════════════════════════════════════════════════════

# ── Security ──────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_MINIMUM_256_BIT_RANDOM_SECRET

# ── Spring ────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=production

# ── CORS (comma-separated, no trailing slash) ─────────────────
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com

# ── Gateway port (host-side) ──────────────────────────────────
GATEWAY_PORT=8080

# ── Database ──────────────────────────────────────────────────
DB_USERNAME=healthlife
# Generate: openssl rand -base64 32
DB_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD

# ── Redis ─────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD

# ── Mail / SMTP ───────────────────────────────────────────────
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_USERNAME=your-app@gmail.com
MAIL_PASSWORD=your-smtp-app-password

# ── Stripe (leave empty to disable payments) ──────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PREMIUM=price_...
STRIPE_PRICE_FAMILY=price_...
STRIPE_SUCCESS_URL=https://app.yourdomain.com/subscription/success
STRIPE_CANCEL_URL=https://app.yourdomain.com/subscription/cancel

# ── AI Services ───────────────────────────────────────────────
# DeepSeek API key for ai-coach-service (leave empty to disable)
DEEPSEEK_API_KEY=

# Anthropic API key for mental-service support chat (leave empty to disable)
ANTHROPIC_API_KEY=

# ── OAuth (leave empty to disable) ───────────────────────────
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_APPLE_AUDIENCE=

# ── Firebase FCM (paste single-line JSON, leave empty to disable) ──
FIREBASE_SERVICE_ACCOUNT_JSON=
