# ─── Maven ────────────────────────────────────────────────────────────────────
target/
*.jar
*.class
*.war
*.ear

# ─── Node / Expo ──────────────────────────────────────────────────────────────
node_modules/
.expo/
.expo-shared/
dist/
build/
*.tsbuildinfo

# ─── IDE ──────────────────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/
*.swp
*.swo
*.orig

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Секреты и переменные окружения — НИКОГДА не коммитить ───────────────────
.env
.env.local
.env.*.local
*.env.local
application-local.properties
application-local.yml
secrets/
**/src/main/resources/application-prod.yml
**/src/main/resources/application-production.yml

# ─── Kubernetes секреты — только шаблоны в репозитории ───────────────────────
k8s/base/secrets.yaml

# ─── Логи и временные файлы ───────────────────────────────────────────────────
*.log
*.log.*
*.tmp
*.temp
*.bak
*.cache

# ─── Отчёты тестов и покрытия ─────────────────────────────────────────────────
**/target/surefire-reports/
**/target/site/
**/target/jacoco.exec

# ─── OWASP отчёты (могут содержать чувствительные данные о зависимостях) ──────
**/dependency-check-report.*
**/dependency-check-data/

# ─── Docker ───────────────────────────────────────────────────────────────────
.dockerignore.local

# ─── Package lock (генерируется автоматически) ────────────────────────────────
package-lock.json
