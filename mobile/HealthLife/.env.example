# HealthLife Mobile — Environment Variables
# Copy to .env.local and fill in values.
# NEVER commit .env.local to git.
#
# Usage with Ngrok tunnel (physical iPhone):
#   1. Start your backend: kubectl port-forward svc/gateway-service 8080:80 -n healthlife
#   2. Start Ngrok: ngrok http 8080
#   3. Copy the https URL from Ngrok output (e.g. https://xxxx.ngrok-free.app)
#   4. Set EXPO_PUBLIC_API_URL below
#   5. Run: npx expo start --tunnel
#
# Usage with Android emulator (no Ngrok needed):
#   Leave EXPO_PUBLIC_API_URL empty — app will use http://10.0.2.2:8080 automatically
#
# Usage with iOS simulator on same machine:
#   Leave EXPO_PUBLIC_API_URL empty — app will use http://localhost:8080

# Backend API URL — overrides all platform defaults when set
# Set to your Ngrok URL for physical device testing
EXPO_PUBLIC_API_URL=
